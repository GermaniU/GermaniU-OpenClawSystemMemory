    },
    "memory_facts": {
      "vectorSize": 768,
      "distance": "Cosine",
      "description": "Hechos, conocimientos y datos importantes"
    },
    "memory_tasks": {
      "vectorSize": 768,
      "distance": "Cosine",
      "description": "Tareas pendientes y TODOs"
    }
  }
}
