{
  "qdrantUrl": "http://localhost:6333",
  "defaultCollection": "memory_incidents",
  "embeddingModel": "nomic-embed-text",
  "embeddingProxyUrl": "http://localhost:18789",
  "collections": {
    "memory_incidents": {
      "vectorSize": 768,
      "distance": "Cosine",
