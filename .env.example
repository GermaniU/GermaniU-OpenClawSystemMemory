# ─── Embeddings ───────────────────────────────────────────────────────────
# Modelo y dimensión. Asegúrate de que tu endpoint Ollama soporte el modelo.
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024

# ─── Ollama (cualquier endpoint compatible con /api/embeddings) ──────────
# Modo A — Ollama Cloud:
OLLAMA_URL=https://ollama.com
OLLAMA_API_KEY=tu_api_key_aqui
#
# Modo B — Ollama local en tu Mac (descomentar y borrar API key):
# OLLAMA_URL=http://host.docker.internal:11434
# OLLAMA_API_KEY=
#
# Modo C — Ollama remoto (tu servidor):
# OLLAMA_URL=https://ollama.tu-dominio.com
# OLLAMA_API_KEY=opcional_si_pones_proxy_con_auth

# ─── Qdrant ───────────────────────────────────────────────────────────────
# Por defecto el servicio "qdrant" del docker-compose. Si corres el MCP
# server fuera de docker, apunta esto a un Qdrant que ya tengas.
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=openclaw_memory

# ─── MCP server ───────────────────────────────────────────────────────────
MCP_PORT=8765
DEFAULT_NAMESPACE=default
